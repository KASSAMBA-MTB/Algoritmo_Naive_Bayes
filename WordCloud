      "source": [
        "# Instalar pacotes necessários (caso não estejam instalados)\n",
        "# pip install wordcloud matplotlib\n",
        "\n",
        "from wordcloud import WordCloud\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib import colormaps\n",
        "\n",
        "# Dados de exemplo: palavras e frequências\n",
        "texto = {\n",
        "    \"requisitos\": 15,\n",
        "    \"negócios\": 10,\n",
        "    \"técnicos\": 8,\n",
        "    \"análise\": 12,\n",
        "    \"processo\": 7,\n",
        "    \"stakeholders\": 5,\n",
        "    \"priorização\": 6,\n",
        "    \"validação\": 8,\n",
        "    \"desenvolvimento\": 9,\n",
        "    \"documentação\": 4,\n",
        "    \"sistemas\": 3,\n",
        "    \"projetos\": 5,\n",
        "    \"gestão\": 6,\n",
        "    \"software\": 2\n",
        "}\n",
        "\n",
        "# Definir semente para reprodutibilidade\n",
        "random_state = 123\n",
        "\n",
        "# Criar a nuvem de palavras\n",
        "wordcloud = WordCloud(\n",
        "    width=800,\n",
        "    height=400,\n",
        "    background_color=\"white\",\n",
        "    max_words=100,\n",
        "    random_state=random_state,\n",
        "    colormap=\"Dark2\"\n",
        ").generate_from_frequencies(texto)\n",
        "\n",
        "# Exibir a nuvem de palavras\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.imshow(wordcloud, interpolation=\"bilinear\")\n",
        "plt.axis(\"off\")\n",
        "plt.title(\"Nuvem de Palavras - Análise de Negócios\", fontsize=16)\n",
        "plt.show()"
      ]
